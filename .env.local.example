# Supabase PostgreSQL via Prisma
DATABASE_URL="postgresql://postgres.XXXXXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.XXXXXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# JWT Secret (generá con: openssl rand -base64 32)
JWT_SECRET="secreto-largo-y-aleatorio-minimo-32-chars"

# Cron secret — protege el endpoint de sync automático
CRON_SECRET="un-secreto-largo-y-aleatorio"

# football-data.org — RECOMENDADO, free tier incluye Copa del Mundo
# Registrate en https://www.football-data.org/client/register y pegá tu token
FOOTBALL_DATA_KEY="tu_token_aqui"

# API-Football — alternativa (requiere plan pago para temporada 2026)
API_FOOTBALL_KEY="tu_api_key_aqui"
